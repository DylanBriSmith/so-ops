[Unit]
Description=SO Daily Health Report
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
User=soops
WorkingDirectory=/opt/so-ops
ExecStart=/usr/bin/docker compose run --rm so-ops health
StandardOutput=journal
StandardError=journal
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
